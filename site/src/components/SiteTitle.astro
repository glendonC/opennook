---
import NookMark from './NookMark.astro';

const siteTitle = 'OpenNook';
---

<a href="/" class="site-title sl-flex">
  <NookMark class="site-title__mark" width={16} height={16} />
  <span translate="no">{siteTitle}</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: 0.55rem;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-title:hover {
    opacity: 0.82;
  }

  .site-title__mark {
    opacity: 0.88;
  }
</style>
