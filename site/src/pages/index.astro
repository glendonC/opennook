---
const repoUrl = 'https://github.com/athledev-labs/opennook';
const docsUrl = '/start/introduction/';
import '../styles/tokens.css';
const carouselLines = [
  'Hover to expand',
  'Home view + top bar chrome',
  'Lock to stay open',
];
---

<!doctype html>
<html lang="en" data-palette="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <title>OpenNook - Notch apps for macOS</title>
    <meta name="description" content="An open-source Swift framework for the menu-bar notch." />
    <meta property="og:title" content="OpenNook" />
    <meta property="og:description" content="An open-source Swift framework for the menu-bar notch." />
    <meta property="og:url" content="https://opennook.dev" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://opennook.dev/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://opennook.dev/og-image.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href="https://opennook.dev/" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300..700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a href="#hero" class="visually-hidden">Skip to content</a>

    <main id="hero" class="page">
      <div class="nook-host is-interactive" data-palette="dark" data-theme-mode="dark" data-surface="solid">
        <div class="nook-trigger" tabindex="0" aria-label="OpenNook - hover for more details">
          <div class="notch-carousel" data-notch-carousel aria-live="polite">
            <div class="notch-carousel__viewport">
              {carouselLines.map((line, index) => (
                <p
                  class:list={['notch-carousel__line', { 'is-active': index === 0 }]}
                  data-carousel-line
                >
                  {line}
                </p>
              ))}
            </div>
          </div>

          <article class="stage" aria-label="OpenNook demo surface">
            <div class="stage__content">
              <div class="stage__body">
          <header class="bar">
            <div class="bar__date" data-bar-date>
              <time class="bar__date-label" datetime="" data-bar-date-label>Sat, May 23</time>
            </div>
            <span class="bar__spacer"></span>
            <div class="bar__trailing">
              <button type="button" class="bar__icon" data-keep-open aria-label="Stay expanded after hover" aria-pressed="false">
                <svg class="bar__icon-lock-open" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 9.9-1" />
                </svg>
                <svg class="bar__icon-lock-closed" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              </button>
              <span class="bar__icon bar__icon--settings" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </span>
            </div>
          </header>

          <div class="surface-body">
            <div class="home-surface">
              <div class="placeholder-home">
                <svg class="placeholder-home__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
                  <path d="M5 10.5c0-3 3.1-6 7-6s7 3 7 6" />
                  <circle cx="12" cy="16" r="2" fill="currentColor" stroke="none" />
                </svg>
                <p class="placeholder-home__title">Nook</p>
                <p class="placeholder-home__body">Register your own view with NookConfiguration to start building.</p>
              </div>
            </div>
          </div>
          </div>
        </div>
      </article>
        </div>
      </div>

      <aside class="mobile-notice" data-mobile-notice hidden>
        <p class="mobile-notice__text">
          This interactive demo is built for Mac notch surfaces.
          Tap the notch to preview it here, or open on a Mac for the full experience.
        </p>
        <button type="button" class="mobile-notice__dismiss" data-mobile-notice-dismiss aria-label="Dismiss notice">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M18 6 6 18" />
            <path d="m6 6 12 12" />
          </svg>
        </button>
      </aside>

      <section class="screen-hero" aria-label="OpenNook overview">
        <h1 class="screen-hero__title">Notch apps<br />for macOS.</h1>
        <p class="screen-hero__subtitle">
          An open-source Swift framework for the menu-bar notch.
        </p>

        <div class="screen-hero__actions">
          <a class="hero-btn" href={docsUrl}>
            <svg class="hero-btn__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 7v14" />
              <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" />
            </svg>
            Docs
          </a>
          <a class="hero-btn" href={repoUrl}>
            <svg class="hero-btn__icon" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.66.5 12.04c0 5.1 3.29 9.43 7.86 10.95.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.35.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.72 0-1.27.45-2.3 1.19-3.11-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.19a11 11 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.21-1.5 3.18-1.19 3.18-1.19.63 1.59.24 2.76.12 3.05.74.81 1.19 1.84 1.19 3.11 0 4.45-2.7 5.43-5.27 5.71.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.79.56C20.21 21.46 23.5 17.13 23.5 12.04 23.5 5.66 18.35.5 12 .5Z" />
            </svg>
            GitHub
          </a>
        </div>
      </section>

      <p class="version" aria-hidden="true">v0.2.0</p>
    </main>

    <script>
      const nookHost = document.querySelector('.nook-host');
      const nookTrigger = document.querySelector('.nook-trigger');
      const keepOpenBtn = document.querySelector('[data-keep-open]');
      const barDateLabel = document.querySelector('[data-bar-date-label]');
      const carousel = document.querySelector('[data-notch-carousel]');
      const carouselLines = carousel?.querySelectorAll('[data-carousel-line]');
      const mobileNotice = document.querySelector('[data-mobile-notice]');
      const mobileNoticeDismiss = document.querySelector('[data-mobile-notice-dismiss]');

      const formatBarDate = (date = new Date()) => {
        return new Intl.DateTimeFormat('en-US', {
          weekday: 'short',
          month: 'short',
          day: 'numeric',
        }).format(date);
      };

      const updateBarDate = () => {
        const now = new Date();
        if (!barDateLabel) return;
        barDateLabel.textContent = formatBarDate(now);
        barDateLabel.dateTime = now.toISOString().slice(0, 10);
      };

      updateBarDate();

      if (keepOpenBtn && nookHost) {
        keepOpenBtn.addEventListener('click', () => {
          const next = !keepOpenBtn.classList.contains('is-active');
          keepOpenBtn.classList.toggle('is-active', next);
          keepOpenBtn.setAttribute('aria-pressed', String(next));
          nookHost.classList.toggle('is-pinned', next);
          if (next) nookHost.classList.add('is-expanded');
        });
      }

      if (carousel && carouselLines?.length) {
        let carouselIndex = 0;
        let carouselTimer = 0;
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const showCarouselLine = (index) => {
          carouselLines.forEach((line, i) => {
            line.classList.toggle('is-active', i === index);
          });
          carouselIndex = index;
        };

        const stopCarousel = () => {
          window.clearInterval(carouselTimer);
          carouselTimer = 0;
        };

        const startCarousel = () => {
          stopCarousel();
          if (reducedMotion || carouselLines.length < 2) return;
          carouselTimer = window.setInterval(() => {
            showCarouselLine((carouselIndex + 1) % carouselLines.length);
          }, 3200);
        };

        startCarousel();

        if (nookHost) {
          nookHost.addEventListener('mouseenter', stopCarousel, true);
          nookHost.addEventListener('mouseleave', startCarousel, true);
          nookHost.addEventListener('focusin', stopCarousel, true);
          nookHost.addEventListener('focusout', (event) => {
            if (!nookHost.contains(event.relatedTarget)) startCarousel();
          }, true);
        }
      }

      if (nookHost && nookTrigger) {
        const noHover = window.matchMedia('(hover: none)').matches;
        let collapseTimer = 0;

        const isExpanded = () =>
          nookHost.classList.contains('is-expanded') || nookHost.classList.contains('is-pinned');

        const expand = () => {
          window.clearTimeout(collapseTimer);
          nookHost.classList.add('is-expanded');
          nookTrigger.setAttribute('aria-expanded', 'true');
        };

        const collapse = () => {
          if (nookHost.classList.contains('is-pinned')) return;
          window.clearTimeout(collapseTimer);
          nookHost.classList.remove('is-expanded');
          nookTrigger.setAttribute('aria-expanded', 'false');
        };

        const scheduleCollapse = () => {
          if (nookHost.classList.contains('is-pinned')) return;
          window.clearTimeout(collapseTimer);
          collapseTimer = window.setTimeout(collapse, 120);
        };

        if (noHover) {
          nookHost.classList.add('is-touch');
          nookTrigger.setAttribute('aria-expanded', 'false');
          nookTrigger.setAttribute('aria-label', 'OpenNook demo - tap to expand');

          const firstCarouselLine = carousel?.querySelector('[data-carousel-line]');
          if (firstCarouselLine) firstCarouselLine.textContent = 'Tap to expand';

          if (mobileNotice && sessionStorage.getItem('opennook-mobile-notice-dismissed') !== '1') {
            mobileNotice.hidden = false;
            mobileNotice.classList.add('is-visible');
          }

          mobileNoticeDismiss?.addEventListener('click', () => {
            mobileNotice.hidden = true;
            mobileNotice.classList.remove('is-visible');
            sessionStorage.setItem('opennook-mobile-notice-dismissed', '1');
          });

          nookTrigger.addEventListener('click', (event) => {
            if (isExpanded()) return;
            if (event.target.closest('[data-keep-open]')) {
              return;
            }
            expand();
          });

          document.addEventListener('click', (event) => {
            if (!isExpanded()) return;
            if (nookHost.contains(event.target)) return;
            collapse();
          });
        } else {
          nookTrigger.addEventListener('mouseenter', expand);
          nookTrigger.addEventListener('mouseleave', (event) => {
            if (nookHost.contains(event.relatedTarget)) return;
            scheduleCollapse();
          });
          nookTrigger.addEventListener('focusin', expand);
          nookTrigger.addEventListener('focusout', (event) => {
            if (!nookTrigger.contains(event.relatedTarget)) {
              scheduleCollapse();
            }
          });
          nookHost.addEventListener('mouseleave', (event) => {
            if (nookHost.classList.contains('is-pinned')) return;
            if (nookHost.contains(event.relatedTarget)) return;
            scheduleCollapse();
          });
        }
      }
    </script>

    <style is:global>
      :root {
        --notch: #050505;
        --notch-text: #f0eee6;
        --notch-text-soft: rgba(240, 238, 230, 0.6);
        --notch-text-faint: rgba(240, 238, 230, 0.42);
        --notch-line: rgba(240, 238, 230, 0.08);
        --notch-line-strong: rgba(240, 238, 230, 0.14);

        --stage-w: min(520px, calc(100vw - 24px));
        --stage-h: min(340px, max(280px, 55dvh));
        --accent: #0a84ff;
        --notch-pill-w: clamp(150px, 22vw, 200px);
        --notch-pill-h: clamp(26px, 3vw, 30px);
        --notch-carousel-w: clamp(240px, 46vw, 340px);
        --compact-radius: 14px;
        --stage-radius: clamp(28px, 4.5vw, 48px);

        --ease-spring: cubic-bezier(0.32, 0.72, 0, 1);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        font-family: var(--font-sans);
        font-feature-settings: 'ss01', 'ss03';
        color: var(--ink);
        background: var(--page-bg);
        background-image:
          radial-gradient(at 20% 0%, var(--page-glow-a) 0, transparent 55%),
          radial-gradient(at 80% 100%, var(--page-glow-b) 0, transparent 60%);
        min-height: 100dvh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      html[data-palette='light'] {
        color-scheme: light;
      }

      html[data-palette='dark'] {
        color-scheme: dark;
      }

      .nook-host[data-palette='light'] {
        --notch: #f5f2ea;
        --notch-text: #0a0a0a;
        --notch-text-soft: rgba(10, 10, 10, 0.58);
        --notch-text-faint: rgba(10, 10, 10, 0.42);
        --notch-line: rgba(10, 10, 10, 0.08);
        --notch-line-strong: rgba(10, 10, 10, 0.14);
      }

      .nook-host[data-palette='dark'] {
        --notch: #050505;
        --notch-text: #f0eee6;
        --notch-text-soft: rgba(240, 238, 230, 0.6);
        --notch-text-faint: rgba(240, 238, 230, 0.42);
        --notch-line: rgba(240, 238, 230, 0.08);
        --notch-line-strong: rgba(240, 238, 230, 0.14);
      }

      .nook-host[data-surface='translucent'] .stage,
      .nook-host[data-surface='translucent'] .notch-carousel {
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
      }

      .nook-host[data-surface='translucent'][data-palette='dark'] .stage,
      .nook-host[data-surface='translucent'][data-palette='dark'] .notch-carousel {
        background: rgba(5, 5, 5, 0.72);
      }

      .nook-host[data-surface='translucent'][data-palette='light'] .stage,
      .nook-host[data-surface='translucent'][data-palette='light'] .notch-carousel {
        background: rgba(245, 242, 234, 0.72);
      }

      .visually-hidden {
        position: absolute;
        width: 1px; height: 1px;
        padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0, 0, 0, 0);
        white-space: nowrap; border: 0;
      }

      .page {
        position: relative;
        min-height: 100dvh;
        display: block;
        isolation: isolate;
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
        padding-bottom: max(0px, env(safe-area-inset-bottom));
      }

      .page::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(ellipse 80% 55% at 18% 0%, rgba(110, 150, 210, 0.14) 0, transparent 70%),
          radial-gradient(ellipse 70% 50% at 82% 8%, rgba(210, 130, 90, 0.1) 0, transparent 65%),
          radial-gradient(ellipse 90% 60% at 50% 0%, rgba(255, 255, 255, 0.28) 0, transparent 72%);
      }

      html[data-palette='dark'] .page::before {
        background:
          radial-gradient(ellipse 80% 55% at 18% 0%, rgba(90, 130, 200, 0.1) 0, transparent 70%),
          radial-gradient(ellipse 70% 50% at 82% 8%, rgba(200, 110, 70, 0.08) 0, transparent 65%),
          radial-gradient(ellipse 90% 60% at 50% 0%, rgba(255, 255, 255, 0.03) 0, transparent 72%);
      }

      /* ---- NOOK HOST ---- */
      .nook-host {
        position: relative;
        z-index: 1;
        width: var(--stage-w);
        margin: 0 auto;
        transition: padding-top 460ms var(--ease-spring);
      }

      .nook-host.is-interactive.is-expanded,
      .nook-host.is-interactive.is-open,
      .nook-host.is-interactive.is-pinned {
        z-index: 10;
      }

      /* ---- Mobile / touch notice ---- */
      .mobile-notice {
        position: relative;
        z-index: 2;
        display: none;
        align-items: flex-start;
        gap: 10px;
        width: min(520px, calc(100vw - 24px));
        margin: 12px auto 0;
        padding: 10px 12px;
        border: 1px solid rgba(10, 10, 10, 0.1);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.55);
        backdrop-filter: blur(8px);
      }

      .mobile-notice.is-visible {
        display: flex;
      }

      html[data-palette='dark'] .mobile-notice {
        border-color: rgba(240, 238, 230, 0.12);
        background: rgba(10, 10, 10, 0.35);
      }

      .mobile-notice__text {
        flex: 1;
        margin: 0;
        font-size: 12px;
        line-height: 1.45;
        color: var(--ink-muted);
      }

      .mobile-notice__dismiss {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        margin: -4px -4px -4px 0;
        padding: 0;
        border: 0;
        border-radius: 8px;
        background: transparent;
        color: var(--ink-faint);
        cursor: pointer;
      }

      /* ---- SCREEN COPY (cream page, visible when compact) ---- */
      .screen-hero {
        position: relative;
        z-index: 1;
        width: fit-content;
        max-width: min(560px, calc(100vw - 48px));
        margin-inline: auto;
        padding: clamp(28px, 7vh, 72px) 12px 0;
        text-align: left;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 420ms var(--ease-out), transform 420ms var(--ease-out);
      }

      .screen-hero__title {
        margin: 0 0 clamp(10px, 1.2vw, 16px);
        font-size: clamp(30px, 5.2vw, 52px);
        line-height: 1.04;
        letter-spacing: -0.038em;
        font-weight: 600;
        color: var(--ink);
      }

      .screen-hero__subtitle {
        margin: 0 0 clamp(24px, 3vh, 32px);
        max-width: 44ch;
        font-size: clamp(13px, 1.2vw, 15px);
        line-height: 1.5;
        color: var(--ink-muted);
      }

      .screen-hero__actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
      }

      .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        font-size: 13.5px;
        font-weight: 500;
        letter-spacing: -0.01em;
        line-height: 1;
        color: var(--ink);
        text-decoration: none;
        background: transparent;
        border: 1px solid rgba(10, 10, 10, 0.12);
        border-radius: 8px;
      }

      html[data-palette='dark'] .hero-btn {
        border-color: rgba(240, 238, 230, 0.16);
      }

      .hero-btn:hover {
        border-color: rgba(10, 10, 10, 0.32);
      }

      html[data-palette='dark'] .hero-btn:hover {
        border-color: rgba(240, 238, 230, 0.34);
      }

      .hero-btn__icon {
        flex: 0 0 15px;
      }

      .page:has(.nook-host.is-interactive) .screen-hero {
        opacity: 1;
        transform: translateY(0);
      }

      /* ---- NOOK TRIGGER + CAROUSEL + STAGE ---- */
      .nook-trigger {
        position: relative;
        z-index: 2;
        width: min(var(--notch-carousel-w), 100%);
        max-width: 100%;
        height: var(--notch-pill-h);
        margin: 0 auto;
        outline: none;
      }

      /* Full-surface hit target when compact. The stage sits above visually
         but must not steal hover from the center notch gap. */
      .nook-trigger::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 4;
        border-radius: inherit;
        pointer-events: none;
      }

      .nook-host.is-interactive:not(.is-expanded):not(.is-open) .nook-trigger::before {
        pointer-events: auto;
        cursor: default;
      }

      .notch-carousel {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100%;
        background: var(--notch);
        border-radius: 0 0 7px 7px;
        box-shadow: none;
        opacity: 0;
        pointer-events: none;
        overflow: hidden;
        transition:
          opacity 320ms var(--ease-out),
          border-radius 460ms var(--ease-spring),
          box-shadow 320ms ease;
      }

      .notch-carousel__viewport {
        position: relative;
        width: 100%;
        height: 100%;
      }

      .notch-carousel__line {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: 0 14px;
        font-size: clamp(10px, 1.35vw, 12px);
        font-weight: 500;
        letter-spacing: 0.01em;
        line-height: 1.2;
        text-align: center;
        color: var(--notch-text-soft);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        opacity: 0;
        transform: translateY(5px);
        transition: opacity 420ms var(--ease-out), transform 420ms var(--ease-out);
      }

      .notch-carousel__line.is-active {
        opacity: 1;
        transform: translateY(0);
      }

      .nook-host.is-interactive:not(.is-expanded):not(.is-open) .notch-carousel {
        opacity: 1;
        pointer-events: auto;
      }

      .nook-host.is-interactive.is-expanded .notch-carousel,
      .nook-host.is-interactive.is-open .notch-carousel {
        opacity: 0;
        pointer-events: none;
      }

      .nook-host.is-interactive .nook-trigger {
        transition:
          width 460ms var(--ease-spring),
          height 460ms var(--ease-spring);
      }

      .nook-host.is-interactive:not(.is-expanded):not(.is-open) .nook-trigger {
        width: min(var(--notch-carousel-w), 100%);
        height: var(--notch-pill-h);
      }

      .nook-host.is-interactive.is-expanded .nook-trigger,
      .nook-host.is-interactive.is-open .nook-trigger {
        width: var(--stage-w);
        height: var(--stage-h);
        pointer-events: none;
      }

      .nook-host.is-interactive.is-expanded .stage,
      .nook-host.is-interactive.is-open .stage {
        pointer-events: auto;
      }

      .stage {
        position: absolute;
        inset: 0;
        z-index: 0;
        background: var(--notch);
        border-radius: 0 0 var(--stage-radius) var(--stage-radius);
        box-shadow: none;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform-origin: 50% 0%;
        clip-path: inset(0 round 0 0 var(--compact-radius) var(--compact-radius));
        transition:
          opacity 280ms ease,
          clip-path 460ms var(--ease-spring),
          border-radius 460ms var(--ease-spring),
          box-shadow 320ms ease;
      }

      .nook-host.is-interactive .stage {
        visibility: visible;
        transition:
          opacity 280ms ease,
          clip-path 460ms var(--ease-spring),
          box-shadow 320ms ease,
          z-index 0ms linear 460ms;
      }

      .nook-host.is-interactive:not(.is-expanded):not(.is-open) .stage {
        z-index: 0;
        opacity: 0;
        clip-path: inset(0 round 0 0 var(--compact-radius) var(--compact-radius));
        box-shadow: none;
        pointer-events: none;
      }

      .nook-host.is-interactive.is-expanded .stage,
      .nook-host.is-interactive.is-open .stage {
        z-index: 2;
        transition:
          opacity 280ms ease,
          clip-path 460ms var(--ease-spring),
          border-radius 460ms var(--ease-spring),
          box-shadow 320ms ease,
          z-index 0ms linear 0ms;
        opacity: 1;
        clip-path: inset(0 round 0 0 var(--stage-radius) var(--stage-radius));
        box-shadow:
          0 24px 50px rgba(10, 10, 10, 0.28),
          0 60px 120px rgba(10, 10, 10, 0.14);
        pointer-events: auto;
      }

      .stage__content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
      }

      .stage__body {
        position: relative;
        flex: 1;
        min-height: 0;
        z-index: 1;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        color: var(--notch-text);
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 280ms ease, transform 420ms var(--ease-out);
      }

      .nook-host.is-interactive .stage__body {
        animation: none;
      }

      .nook-host.is-interactive:not(.is-expanded):not(.is-open) .stage__body {
        opacity: 0;
        transform: translateY(8px);
        pointer-events: none;
      }

      .nook-host.is-interactive.is-expanded .stage__body,
      .nook-host.is-interactive.is-open .stage__body {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      .surface-body {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      /* ---- Top bar (matches NookTopBar) ---- */
      .bar {
        display: flex;
        align-items: center;
        gap: 8px;
        height: 24px;
        flex: 0 0 auto;
      }

      .bar__date {
        display: inline-flex;
        align-items: center;
        flex: 0 0 auto;
        color: var(--notch-text-soft);
        font-size: 11px;
        font-weight: 400;
        line-height: 1;
        white-space: nowrap;
      }

      .bar__date-label {
        font: inherit;
        color: inherit;
      }

      .bar__spacer {
        flex: 1;
        min-width: 0;
      }

      .bar__trailing {
        display: flex;
        align-items: center;
        gap: 4px;
        flex: 0 0 auto;
      }

      .bar__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        color: var(--notch-text-faint);
        border: 0;
        border-radius: 7px;
        background: transparent;
        padding: 0;
        cursor: pointer;
      }

      .bar__icon-lock-closed {
        display: none;
      }

      .bar__icon.is-active {
        color: var(--accent);
      }

      .bar__icon.is-active .bar__icon-lock-open {
        display: none;
      }

      .bar__icon.is-active .bar__icon-lock-closed {
        display: block;
      }

      .bar__icon--settings {
        pointer-events: none;
        cursor: default;
      }

      .is-hidden {
        display: none !important;
      }

      /* ---- Home surface (NookPlaceholderHomeView) ---- */
      .home-surface {
        flex: 1;
        min-height: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        padding: clamp(8px, 2dvh, 16px) 0;
      }

      .placeholder-home {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: clamp(6px, 1.5dvh, 10px);
        width: 100%;
        padding: clamp(12px, 4dvh, 32px) 12px;
        text-align: center;
      }

      .placeholder-home__icon {
        color: var(--notch-text-soft);
      }

      .placeholder-home__title {
        margin: 0;
        font-size: 14px;
        font-weight: 500;
        color: var(--notch-text);
      }

      .placeholder-home__body {
        margin: 0;
        max-width: 28ch;
        font-size: 11px;
        line-height: 1.45;
        color: var(--notch-text-faint);
      }


      /* ---- Page version strip ---- */
      .version {
        position: fixed;
        bottom: 22px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--ink-faint);
        margin: 0;
        letter-spacing: 0.04em;
        opacity: 0;
        transition: opacity 600ms var(--ease-out);
      }

      .page:has(.nook-host.is-interactive) .version {
        opacity: 1;
      }

      /* ---- Reduced motion ---- */
      @media (prefers-reduced-motion: reduce) {
        .stage,
        .stage__body,
        .screen-hero,
        .notch-carousel,
        .version {
          animation: none;
          transition: none;
          opacity: 1;
          transform: none;
        }
        .stage {
          width: var(--stage-w);
          clip-path: inset(0 round 0 0 var(--stage-radius) var(--stage-radius));
        }
        .notch-carousel { display: none; }
        .page:has(.nook-host.is-interactive:not(.is-expanded):not(.is-open)) .screen-hero {
          opacity: 1;
        }
        .nook-host.is-interactive.is-expanded .nook-trigger,
        .nook-host.is-interactive.is-open .nook-trigger,
        .nook-host.is-interactive.is-expanded .stage,
        .nook-host.is-interactive.is-open .stage {
          width: var(--stage-w);
          height: var(--stage-h);
          clip-path: inset(0 round 0 0 var(--stage-radius) var(--stage-radius));
        }
      }

      /* ---- Narrow viewport tuning ---- */
      @media (max-width: 520px) {
        :root {
          --notch-carousel-w: min(100%, calc(100vw - 24px));
          --stage-h: min(340px, max(260px, 62dvh));
        }
        .mobile-notice {
          width: min(100%, calc(100vw - 24px));
        }
        .screen-hero__subtitle { max-width: none; }
        .notch-carousel__line {
          white-space: normal;
          font-size: 10.5px;
        }
        .placeholder-home {
          padding: 12px 12px 16px;
        }
        .placeholder-home__icon {
          width: 22px;
          height: 22px;
        }
        .hero-btn {
          min-height: 44px;
          padding: 10px 16px;
        }
      }

      /* ---- Touch surfaces ---- */
      @media (hover: none) {
        .bar__icon {
          width: 44px;
          height: 44px;
        }

        .bar {
          height: 44px;
        }
      }

      /* ---- Landscape phones / short viewports ----
         When the viewport is shorter than the stage's min-height would
         normally allow, --stage-h already clamps with a floor. Hide the
         fixed version strip so it doesn't crowd the stage's bottom edge. */
      @media (max-height: 480px) {
        :root {
          --stage-h: min(340px, max(240px, 72dvh));
        }
        .placeholder-home {
          padding: 10px 12px 14px;
          gap: 6px;
        }
        .placeholder-home__body {
          font-size: 10.5px;
          line-height: 1.4;
        }
        .version { display: none; }
      }
    </style>
  </body>
</html>
